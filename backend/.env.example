# Port des HTTP-Servers (Default: 3000)
PORT=3000

# MongoDB-Verbindung. Auskommentiert lassen, um den lokalen
# JSON-Datei-Store (backend/data/db.json) zu verwenden.
# MONGODB_URI=mongodb://127.0.0.1:27017/veranstaltungszeitplaner

# Ablageordner für hochgeladene Bilder (relativ zu backend/, Default: uploads)
UPLOAD_DIR=uploads
